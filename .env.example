# ─────────────────────────────────────────────────────────────────────────────
# 한림대 MICE 동문 플랫폼 — 환경변수 (부록 E)
# 이 파일을 복사해 .env.local 을 만들고 값을 채운다. (.env* 는 절대 커밋 금지)
# 규칙: NEXT_PUBLIC_ 접두어 = 브라우저 노출 OK / 그 외 = 서버 전용(절대 NEXT_PUBLIC 금지)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (DB / Auth)
NEXT_PUBLIC_SUPABASE_URL=            # 공개값 (예: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # 공개값 (브라우저 노출 정상)
SUPABASE_SERVICE_ROLE_KEY=           # 서버 전용 · Prod 환경변수만 · 절대 NEXT_PUBLIC 금지 · lib/supabase/admin.ts 단일 사용처

# 사이트
NEXT_PUBLIC_SITE_URL=                # 공개값 (예: http://localhost:3000 / https://app.example.com) · OAuth 리다이렉트

# Resend (트랜잭션 메일)
RESEND_API_KEY=                      # 서버 전용

# 관리자 부트스트랩
ADMIN_EMAILS=                        # admins 테이블이 비어 있을 때만 허용되는 최초 관리자 Google 이메일

# Cloudflare R2 (이미지 스토리지 — lib/storage 단일 사용처)
R2_ACCOUNT_ID=                       # 서버 전용
R2_BUCKET=                           # 서버 전용 (버킷명)
R2_ACCESS_KEY_ID=                    # 서버 전용 · 절대 NEXT_PUBLIC 금지
R2_SECRET_ACCESS_KEY=                # 서버 전용 · 절대 NEXT_PUBLIC 금지
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=      # 공개값 (r2.dev 또는 커스텀 도메인 — 이미지 읽기 URL 베이스)
